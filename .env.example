# CONTENT_SOURCE can be "auto", "local", or "supabase".
# "auto" tries Supabase when the variables below exist, then falls back to local files.
CONTENT_SOURCE=auto

# Either provide the REST URL directly:
SUPABASE_REST_URL=https://your-project-ref.supabase.co/rest/v1

# Or provide the project URL instead:
# SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key. Keep service-role keys out of this app.
SUPABASE_ANON_KEY=your-anon-public-key
